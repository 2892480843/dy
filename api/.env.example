# OpenAI-compatible LLM for DeepAgents.
# OpenAI official: OPENAI_BASE_URL can stay empty.
# Other compatible providers: set OPENAI_BASE_URL, for example https://api.deepseek.com
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
PLAN_DAY_LLM_TIMEOUT_SECONDS=15

# Qwen3-ASR for Douyin audio transcription.
# Beijing: https://dashscope.aliyuncs.com/compatible-mode/v1
# International: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_ASR_API_KEY=
QWEN_ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_ASR_MODEL=qwen3-asr-flash
QWEN_ASR_STREAM=true

# MiMo TTS. If empty, backend falls back to OPENAI_API_KEY / OPENAI_BASE_URL.
MIMO_TTS_API_KEY=
MIMO_TTS_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_MODEL=mimo-v2.5-tts
MIMO_TTS_VOICE=mimo_default

SEARCH_API_KEY=
AMAP_API_KEY=
WEATHER_API_KEY=
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://47.109.152.106:24812

# ModelScope MCP: 12306
# Source: https://modelscope.cn/mcp/servers/bwxnwnx/12306
# Use either a hosted MCP URL or a local stdio command copied from ModelScope.
MCP_12306_URL=
MCP_12306_TRANSPORT=auto
MCP_12306_BEARER_TOKEN=
MCP_12306_HEADERS=
MCP_12306_COMMAND=
MCP_12306_ARGS=
MCP_12306_ARGS_JSON=
MCP_12306_ENV=

# ModelScope MCP: Hotel_MCP
# Source: https://modelscope.cn/mcp/servers/liu860502/Hotel_MCP
MCP_HOTEL_URL=
MCP_HOTEL_TRANSPORT=auto
MCP_HOTEL_BEARER_TOKEN=
MCP_HOTEL_HEADERS=
MCP_HOTEL_COMMAND=
MCP_HOTEL_ARGS=
MCP_HOTEL_ARGS_JSON=
MCP_HOTEL_ENV=

# Optional shared token used as Bearer token for MCP URLs when per-server token is empty.
MODELSCOPE_SDK_TOKEN=
